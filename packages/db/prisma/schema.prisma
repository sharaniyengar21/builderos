generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  isDemo      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  products    Product[]
  connections Connection[]
}

model Product {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id])
  connections Connection[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([ownerId, name])
}

enum ConnectionStatus {
  CONNECTED
  ERROR
  DISCONNECTED
}

// ownerId is always set (denormalized — one join for demo-guard + auth
// regardless of scope). productId is null for account-wide connections
// (currently only Razorpay — one per business, not tied to a product).
model Connection {
  id                   String           @id @default(cuid())
  ownerId              String
  owner                User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  productId            String?
  product              Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  pluginSlug           String
  externalId           String
  status               ConnectionStatus @default(DISCONNECTED)
  config               Json             @default("{}")
  credentialsEncrypted String?
  lastSyncedAt         DateTime?
  lastSyncError        String?
  snapshots            MetricSnapshot[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // Reconnect-in-place key for product-scoped connections — two different
  // repos are two rows, the same repo reconnected hits the same row.
  // Account-wide dedup (one Razorpay connection per business) is enforced
  // separately by a hand-written partial unique index
  // (Connection_owner_plugin_account_key, WHERE productId IS NULL) that
  // Prisma's schema DSL can't express — see the unify_connections migration.
  @@unique([productId, pluginSlug, externalId])
  @@index([ownerId, pluginSlug])
}

enum SnapshotKind {
  METRIC
  EVENT
}

// value is nullable so purely-structural facts (e.g. "latest release") can live
// in metadata with no numeric value, without needing a schema change per plugin.
model MetricSnapshot {
  id           String           @id @default(cuid())
  connectionId String
  connection   Connection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  kind         SnapshotKind
  key          String
  value        Float?
  metadata     Json?
  occurredAt   DateTime         @default(now())
  createdAt    DateTime         @default(now())

  @@index([connectionId, key, occurredAt])
}
